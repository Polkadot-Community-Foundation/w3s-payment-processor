# W3sPay Payment Processor — build/runtime env. Copy to .env.local (gitignored)
# and adjust per deploy. All VITE_* vars are read once in src/config.ts.

# ── Chain ────────────────────────────────────────────────────────────────
# Active network key: paseo | paseo-next-v2 | previewnet. Must equal BULLETIN_ENV
# at deploy time (deploy.sh enforces this). Coinage + People Next live in v2.
VITE_NETWORK=paseo-next-v2

# Stable SS58 dry-run origin for revive registry reads (v1 remote). Any valid,
# mapped AccountId works; reads are gasless dry-runs. Default: Alice.
# VITE_READ_ONLY_ORIGIN=5GrwvaEF5zXb26Fz9rcQpDWS57CtERHpNehXCPcNoHGKutQY

# ── Token (CASH foreign asset on the People parachain) ─────────────────────
# The Assets.Transferred matcher + Assets.Account balance key are derived from
# these. Defaults target the Paseo People Next CASH asset.
# VITE_TOKEN_SYMBOL=CASH
# VITE_TOKEN_DECIMALS=6
# VITE_TOKEN_PARACHAIN_ID=1500
# VITE_TOKEN_PALLET_INSTANCE=50
# VITE_TOKEN_ASSET_ID=50000413

# ── Host product account (v2 claim wallet) ─────────────────────────────────
# Used to resolve the host product account. v2 claims credit this host wallet
# first; configured payoutAddress values are settlement metadata, not a claim gate.
# VITE_HOST_PRODUCT_DOTNS=w3spaymentprocessor.dot
# VITE_HOST_DERIVATION_INDEX=0

# ── Protocol listener defaults ─────────────────────────────────────────────
# Build-time defaults for whether each protocol starts listening after unlock.
# Merchants can override these on-device in Settings; overrides persist in
# localStorage and take effect immediately.
# VITE_V1_LISTENING_ENABLED=true
# VITE_V2_LISTENING_ENABLED=true

# ── Remote merchant credentials (the v2 secret source) ─────────────────────
# JSON object mapping each POS group id to its encrypted credential bundle URL
# (ipfs://<cid> or https://). CIDs are not secrets; only the merchant passkey
# unlocks the content. Run `npm run upload-credentials` to provision a bundle —
# it prints the exact entry to add here.
#
# VITE_CREDENTIAL_MAP={"funkhaus-pos":"ipfs://bafk..."}
# VITE_CREDENTIAL_MAP={"funkhaus-pos":"ipfs://bafk...","westside":"https://host/w.json"}
#
# IPFS gateway used to resolve ipfs://<cid> entries. Default is Paseo Next v2.
# VITE_BULLETIN_IPFS_GATEWAY=https://paseo-bulletin-next-ipfs.polkadot.io

# ── Debug overlay (optional) ───────────────────────────────────────────────
# In-page debug panel (floating 🐞 toolbox button → console/timeline/host
# tabs). Captures console.* + uncaught errors and the v1/v2 monitor boot
# phases — use it on-device/in-host where there's no DevTools. Defaults ON in
# `vite dev`, OFF in production builds; set true to ship it in a build.
# VITE_DEBUG_PANEL=false
# Open the panel automatically on load instead of starting collapsed.
# VITE_DEBUG_PANEL_OPEN=false

# ── Telemetry (optional) ───────────────────────────────────────────────────
# Empty/unset disables Sentry entirely (no SDK loaded).
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENV=production
# VITE_SENTRY_TRACES_SAMPLE_RATE=1

# ── Deploy secret (NEVER commit a real value) ──────────────────────────────
# 12- or 24-word BIP-39 phrase for bulletin-deploy. Put the real value in
# .env.local, not here.
# MNEMONIC="your twelve word mnemonic phrase goes here only in env local"

# ── Provisioning secret (NEVER commit a real value) ────────────────────────
# Passkey that encrypts/decrypts the remote credential envelope. Used by
# `npm run upload-credentials` and entered by the merchant at unlock. Keep it in
# .env.local or pass it inline; the upload script reads it from the env, never args.
# REMOTE_CREDENTIALS_PASSKEY="a long random merchant unlock passphrase"
